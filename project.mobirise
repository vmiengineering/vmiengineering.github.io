          "_name": "content9",
          "_customHTML": "<section class=\"mbr-section article content9\" group=\"Article\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Text Width\" name=\"innerWidth\" min=\"50\" max=\"100\" step=\"1\" value=\"100\">\n        <input type=\"range\" inline title=\"Line Width\" name=\"lineLength\" min=\"10\" max=\"100\" step=\"1\" value=\"25\">\n        <input type=\"color\" title=\"Line Color\" name=\"lineColor\" value=\"#149dcc\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#ffffff\">\n    <!-- End block parameters -->\n    </mbr-parameters> \n\n    <div class=\"container\">\n        <div class=\"inner-container\" mbr-style=\"{'width': innerWidth + '%'}\">\n            <hr class=\"line\" mbr-style=\"{'width': lineLength + '%'}\">\n            <div class=\"section-text align-center mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".section-text\" mbr-text><div><div>&nbsp;&nbsp;&nbsp;&nbsp;<span style=\"font-size: 1rem;\">AUTODESK offers free educational software for educators and students. Please goto <a href=\"https://www.autodesk.com/education/free-software/featured\" target=\"_blank\">https://www.autodesk.com/education/free-software/featured</a>&nbsp;to see all software available.</span></div></div><br><div><div>&nbsp;&nbsp;&nbsp;&nbsp;<span style=\"font-size: 1rem;\">You <b>must</b> sign up for an account with AUTODESK. Once you create an account sign in and select the version of software, operating system, and language you want.&nbsp;</span><span style=\"font-size: 1rem;\">&nbsp; &nbsp;&nbsp;</span></div></div><div><div><br></div></div><div><div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style=\"font-size: 1rem;\">Please follow the directions provided at the website on how to install, if you have issues installing please<a href=\"https://www.autodesk.com/education/support/edu-contact-us-form\" target=\"_blank\"> contact AUTODESK support here</a> or go to the Barracks Help Desk located in C01-B in New Barracks for assistance, or&nbsp;</span><span style=\"font-size: 1rem;\">you can see the Divisional Engineering IT Specialist in NEB 406.</span></div></div></div>\n            <hr class=\"line\" mbr-style=\"{'width': lineLength + '%'}\">\n        </div>\n        </div>\n</section>",
          "_cid": "rIosAunBez",
          "_anchor": "content9-3p",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
