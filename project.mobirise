        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            ".line": {
              "background-color": "@lineColor",
              "color": "@lineColor",
              "align": "center",
              "height": "2px",
              "margin": "0 auto"
            },
            ".section-text": {
              "padding": "2rem 0",
              "text-align": "left",
              "color": "#232323"
            },
            ".inner-container": {
              "margin": "0 auto"
            },
            "@media (max-width: 768px)": {
              ".inner-container": {
                "width": "100% !important"
              }
            }
          },
          "_name": "content9",
          "_customHTML": "<section class=\"mbr-section article content9\" group=\"Article\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Text Width\" name=\"innerWidth\" min=\"50\" max=\"100\" step=\"1\" value=\"100\">\n        <input type=\"range\" inline title=\"Line Width\" name=\"lineLength\" min=\"10\" max=\"100\" step=\"1\" value=\"25\">\n        <input type=\"color\" title=\"Line Color\" name=\"lineColor\" value=\"#149dcc\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#ffffff\">\n    <!-- End block parameters -->\n    </mbr-parameters> \n\n    <div class=\"container\">\n        <div class=\"inner-container\" mbr-style=\"{'width': innerWidth + '%'}\">\n            <hr class=\"line\" mbr-style=\"{'width': lineLength + '%'}\">\n            <div class=\"section-text align-center mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".section-text\" mbr-text><b>MathCAD 15.0 M045 [ME ONLY - PURCHASE ONLY]\n</b><br><b><br></b><div>&nbsp;&nbsp;&nbsp;&nbsp;The Mechanical Engineering department holds several standalone licenses for MathCAD 15.0 M045.\n</div><div>To purchase a stand alone license please see Charlene Graves to purchase the Product Code ($20)\n</div><div>Once product code is paid for Charlene will notify the Divisional Engineering IT Specialist, then he will send an email to you with directions and your product code\n.<br><br></div><div>- Make sure to keep track of your serial number that will be sent to you\n</div><div>- <a href=\"https://vmiengineering.github.io/documentation/PTC_Mathcad_15.0_M045_Read_This_First.pdf\" target=\"_blank\">Documentation for MathCAD 15.0 M045 can be found here</a></div><br><div><b>MathCAD Express\n (FREE for students and educators)<br><br></b></div><div>&nbsp;&nbsp;&nbsp;&nbsp;PTC offers free-for-life Engineering Math Software. PTC Mathcad Express is free math software that gives lifetime access to selected features of PTC Mathcad Prime 6.0\n<br><br></div><div>- <a href=\"https://www.mathcad.com/en/try-and-buy/mathcad-express-free-download\" target=\"_blank\">Click here to goto https://www.mathcad.com/en/try-and-buy/mathcad-express-free-download to sign up and download the software\n</a></div><div>- Please note that MathCAD Express may not have all the features that are available in MathCAD 15.0 M045 (version used in computer labs),<a href=\"https://www.mathcad.com/en/capabilities/comparison-chart\" target=\"_blank\"> please refer to the comparison chart to see the differences in features of MathCAD Express </a>compared to the version 15.0 M045 <a href=\"https://vmiengineering.github.io/documentation/PTC_Mathcad_15.0_M045_Read_This_First.pdf\" target=\"_blank\">documentation found here</a></div></div>\n            <hr class=\"line\" mbr-style=\"{'width': lineLength + '%'}\">\n        </div>\n        </div>\n</section>",
          "_cid": "rIc3Faw21b",
          "_anchor": "content9-1y",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
