            "@media (min-width: 767px)": {
              ".menu-logo": {
                "flex-shrink": "0",
                "-webkit-flex-shrink": "0"
              }
            },
            ".navbar-collapse": {
              "flex-basis": "auto",
              "-webkit-flex-basis": "auto"
            },
            ".nav-link:hover, .dropdown-item:hover": {
              "color": "@itemsHoverColor !important"
            }
          },
          "_name": "menu1",
          "_customHTML": "<section class=\"menu\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"checkbox\" title=\"Show Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3.8\" max=\"8\" step=\"0.1\" value=\"3.8\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Show Brand Name\" name=\"showBrand\" checked>\n        <input type=\"checkbox\" title=\"Show Menu Items\" name=\"showItems\" checked>\n        <input type=\"color\" title=\"Items Hover Color\" name=\"itemsHoverColor\" value=\"#c1c1c1\" condition=\"showItems\">\n        <input type=\"checkbox\" title=\"Show Button(s)\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\">\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\">\n        <input type=\"color\" title=\"Hamburger Color\" name=\"hamburgerColor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Background Color\" name=\"menuBgColor\" value=\"#333333\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-expand beta-menu navbar-dropdown align-items-center\" mbr-class=\"{'navbar-fixed-top': sticky,\n        'navbar-toggleable-sm': !collapsed,\n        'collapsed': collapsed,\n        'bg-color transparent': transparent}\">\n        <button class=\"navbar-toggler navbar-toggler-right\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" aria-controls=\"navbarSupportedContent\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n            <div class=\"hamburger\">\n                <span></span>\n                <span></span>\n                <span></span>\n                <span></span>\n            </div>\n        </button>\n        <div class=\"menu-logo\">\n            <div class=\"navbar-brand\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"index.html\">\n                         <img src=\"@PROJECT_PATH@/assets/images/vmilogotransparent-122x123.png\" alt mbr-style=\"{'height': logoSize + 'rem'}\" title>\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove\"><a class=\"navbar-caption text-white\" data-app-selector=\".navbar-caption\" href=\"index.html\" data-app-placeholder=\"Type Text\">\n                        VMI ENGINEERING</a></span>\n            </div>\n        </div>\n        <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n            <ul mbr-if=\"showItems\" mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n                    <a class=\"nav-link link text-white\" href=\"https://mobirise.co\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">\n                        </a>\n                </li>\n                <li class=\"nav-item\">\n                    <a class=\"nav-link link text-white\" href=\"https://mobirise.co\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">\n                        </a>\n                </li><li class=\"nav-item\"><a class=\"nav-link link text-white\" href=\"forms.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><span class=\"mbrib-edit mbr-iconfont mbr-iconfont-btn\" style=\"color: rgb(204, 41, 82);\"></span>\n                        Forms</a></li><li class=\"nav-item\"><a class=\"nav-link link text-white\" href=\"3dprint.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\"><span class=\"socicon socicon-buffer mbr-iconfont mbr-iconfont-btn\" style=\"color: rgb(204, 41, 82);\"></span>\n                        3D Printing</a></li><li class=\"nav-item\"><a class=\"nav-link link text-white\" href=\"software.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\"><span class=\"socicon socicon-windows mbr-iconfont mbr-iconfont-btn\" style=\"color: rgb(204, 41, 82);\"></span>\n                        Software&nbsp;</a></li><li class=\"nav-item\"><a class=\"nav-link link text-white\" href=\"Tutorials.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\"><span class=\"socicon socicon-github mbr-iconfont mbr-iconfont-btn\" style=\"color: rgb(204, 41, 82);\"></span>\n                        Tutorials</a></li></ul>\n            <div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-sm btn-secondary\" href=\"index.html\" data-app-placeholder=\"Type Text\"><span class=\"mbrib-home mbr-iconfont mbr-iconfont-btn\" style=\"color: rgb(255, 255, 255);\"></span>\n                    Home</a></div>\n        </div>\n    </nav>\n</section>",
          "_cid": "rIhsCzKF0a",
          "_anchor": "menu1-2f",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            ".line": {
              "background-color": "@lineColor",
              "color": "@lineColor",
              "align": "center",
              "height": "2px",
              "margin": "0 auto"
            },
            ".section-text": {
              "padding": "2rem 0",
              "text-align": "left",
              "color": "#2e2e2e"
            },
            ".inner-container": {
              "margin": "0 auto"
            },
            "@media (max-width: 768px)": {
              ".inner-container": {
                "width": "100% !important"
              }
            },
            ".section-text DIV": {
              "text-align": "left"
            }
          },
          "_name": "content9",
          "_customHTML": "<section class=\"mbr-section article content9\" group=\"Article\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Text Width\" name=\"innerWidth\" min=\"50\" max=\"100\" step=\"1\" value=\"100\">\n        <input type=\"range\" inline title=\"Line Width\" name=\"lineLength\" min=\"10\" max=\"100\" step=\"1\" value=\"25\">\n        <input type=\"color\" title=\"Line Color\" name=\"lineColor\" value=\"#149dcc\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#ffffff\">\n    <!-- End block parameters -->\n    </mbr-parameters> \n\n    <div class=\"container\">\n        <div class=\"inner-container\" mbr-style=\"{'width': innerWidth + '%'}\">\n            <hr class=\"line\" mbr-style=\"{'width': lineLength + '%'}\">\n            <div class=\"section-text align-center mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".section-text\" mbr-text><p><b>PLEASE READ INSTRUCTIONS CAREFULLY</b><br><br><b>IMPORTANT PREREQUISITES&nbsp;<br></b><br>- This is for <b>Windows Operating System only</b>. &nbsp;This is <b>NOT SUPPORTED BY SOLIDWORKS FOR&nbsp;</b>OSX (Mac)<br>- <b>20 GB disk space free</b>, download of Solidworks will fail if space is not available</p><p>- If you<b> DO NOT have (a) previous version(s)</b> of Solidworks installed please skip the \"Uninstall previous versions of Solidworks\" section and proceed to \"Download and install Solidworks Instructions.\"</p><p>- If you <b>DO have (a) previous version(s)</b> of Solidworks you <b>MUST</b> uninstall any prior versions of Solidworks before proceeding. &nbsp;Be sure to do a complete uninstall.<br><br><b>UNINSTALL PREVIOUS VERSIONS OF SOLIDWORKS WITH A COMPLETE UNINSTALL</b><br><br>Please note the following when uninstalling: backup all previous Solidworks Data you want to keep, and note that you can choose to perform a standard, custom, or complete uninstall.<br><br>The standard uninstall removes Program Files and Folders associated with Solidworks products. &nbsp;By default, all Solidworks products for the selected release are specified for a standard uninstall.</p><p>A custom uninstall allows you to choose and removes one or more of the following: Program Files and Folders, registry keys and data folders (Solidworks Toolbox &amp; files and folders from the original download locations..)<br><br><i>A complete uninstall removes the installatoin directories, registry keys, and data folders</i><br><br><b>1</b>. &nbsp;Press the <b>Windows Key (⊞) + R</b>&nbsp;to bring up the run command prompt/textfield.<br><b>2</b>. &nbsp;Type \"<b>appwiz.cpl</b>\" and hit enter to bring up the \"Programs and features\" to uninstall software. &nbsp;Scroll down and select the previous version(s) of Solidworks you are uninstalling.<br><b>3</b>. &nbsp;On the uninstall screen, ensure that the product(s) you want to uninstall is selected (If you uninstall all products, the Solidworks Installation Manager is also uninstalled).<span style=\"font-size: 1rem;\"><br><b>4</b>. &nbsp;Clear the products you do not want to remove, if you retain any product(s), Solidworks Installation Manager is not removed\n<br></span><span style=\"font-size: 1rem;\">Choose whether to perform a custom or complete uninstall (Complete uninstalls are recommended just make sure you have any Solidworks data backed up beforehand).&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>5</b>. &nbsp;Click change in advanced options, the Advanced Options screen appears. The program Files and Folders and Folders option is checked by default.&nbsp;</span><span style=\"font-size: 1rem;\">&nbsp;Select all options to perform a complete uninstall.&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>6</b>. &nbsp;Click Back to Summary.<br></span><span style=\"font-size: 1rem;\"><b>7</b>. &nbsp;On the Summary screen, expand Advanced Options to display the uninstall method and entries&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>8</b>. &nbsp;Click Remove Items&nbsp;</span></p><div><p><b>DOWNLOAD AND INSTALL SOLIDWORKS INSTRUCTIONS</b></p></div><div><p><b>1</b>. &nbsp;<a href=\"https://www.solidworks.com/sw/education/SDL_form.html\" target=\"_blank\">Goto: http://www.solidworks.com/sw/education/SDL_form.html\n</a><br><span style=\"font-size: 1rem;\"><b>2</b>.<b> &nbsp;</b>Fill out the form to request the software and license&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>3</b>. &nbsp;Select \"<b>No</b>\" for \"I already have a Serial Number that starts with 9020:\"&nbsp;<br></span>&nbsp;&nbsp;&nbsp;&nbsp;<span style=\"font-size: 1rem;\">-<b> Please contact your professor or Luke McMasters (mcmasterslj@vmi.edu) for the current years school ID number&nbsp;</b><br></span>&nbsp;&nbsp;&nbsp;&nbsp;<span style=\"font-size: 1rem;\">- Select the newest version&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>4</b>. &nbsp;This will bring you to the terms and conditions page, please read and click Accept Agreement&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>5</b>. &nbsp;You will receive an email from Solidworks with a <b>serial number and expiration date (license good for 365 days)</b>, keep track of this as <b>you will need it during the installation process</b>. Make sure to use the <b>CAD</b> serial number&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>6</b>. &nbsp;At the top of the next page there will be a link for Download which will download the web installer/installation manager&nbsp;<br></span><span style=\"font-size: 1rem;\"><b>7</b>. &nbsp;Run the SolidWorksSetup.exe and allow it to self-extract and bring up the installation <br><b>8</b>. &nbsp;F</span><span style=\"font-size: 1rem;\">ollow the on screen installation directions which will guide you through the complete download and installation process&nbsp;</span></p></div><div><p>\n<span style=\"font-size: 1rem;\">Cadets who are having issues downloading or installing the product please goto the Barracks Help Desk in New Barracks room C01-B. &nbsp;If you are an engineering cadet you can also see the Divisional Engineering IT Specialist in NEB 406.<br></span></p></div></div>\n            <hr class=\"line\" mbr-style=\"{'width': lineLength + '%'}\">\n        </div>\n        </div>\n</section>",
          "_cid": "rIhsCAkJNB",
          "_anchor": "content9-2g",
